-- Teleport Config
local TELEPORT_TARGET_NAME = "GhostHubTP"
local TELEPORT_FALLBACK = CFrame.new(0, 10, 0)
local lastCFrame = nil

local function getTeleportCFrame()
	local target = workspace:FindFirstChild(TELEPORT_TARGET_NAME)
	if target and target:IsA("BasePart") then
		return target.CFrame + Vector3.new(0,3,0)
	end
	return TELEPORT_FALLBACK
end

local function teleportToPoint()
	local char = localPlayer.Character
	if char and char:FindFirstChild("HumanoidRootPart") then
		local hrp = char.HumanoidRootPart
		lastCFrame = hrp.CFrame
		hrp.AssemblyLinearVelocity = Vector3.new()
		hrp.CFrame = getTeleportCFrame()
	end
end

local function returnToLast()
	local char = localPlayer.Character
	if lastCFrame and char and char:FindFirstChild("HumanoidRootPart") then
		local hrp = char.HumanoidRootPart
		hrp.AssemblyLinearVelocity = Vector3.new()
		hrp.CFrame = lastCFrame
	end
end

