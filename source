local emoteFrame = tabs["Emote"]

local function createEmoteButton(parent,text,posY,anim)
	local btn = createButton(parent,text,posY)
	btn.MouseButton1Click:Connect(function()
		pcall(function()
			local event = RS:FindFirstChild("Remotes") and RS.Remotes:FindFirstChild("LobbyRemote")
			if event then event:FireServer("Anim",true,anim) end
		end)
	end)
	return btn
end

