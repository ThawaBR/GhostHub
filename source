-- Helpers
local function createButton(parent,text,posY)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(0.9,0,0,28)
	btn.Position = UDim2.new(0.05,0,0,posY)
	btn.BackgroundColor3 = Color3.fromRGB(60,60,60)
	btn.TextColor3 = Color3.fromRGB(255,255,255)
	btn.Text = text
	btn.Font = Enum.Font.SourceSansBold
	btn.TextSize = 14
	btn.Parent = parent
	return btn
end

local function createTextBox(parent,placeholder,posY)
	local box = Instance.new("TextBox")
	box.Size = UDim2.new(0.9,0,0,25)
	box.Position = UDim2.new(0.05,0,0,posY)
	box.BackgroundColor3 = Color3.fromRGB(80,80,80)
	box.TextColor3 = Color3.fromRGB(255,255,255)
	box.Text = ""
	box.PlaceholderText = placeholder
	box.ClearTextOnFocus = false
	box.Visible = false
	box.Font = Enum.Font.SourceSans
	box.TextSize = 14
	box.Parent = parent
	return box
end

local function createWarningLabel(parent)
	local container = Instance.new("Frame")
	container.Size = UDim2.new(1,-10,0,60)
	container.Position = UDim2.new(0,5,1,-70)
	container.BackgroundTransparency = 1
	container.ClipsDescendants = true
	container.Parent = parent

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1,0,1,0)
	label.Position = UDim2.new(0,0,0,0)
	label.BackgroundTransparency = 0
	label.BackgroundColor3 = Color3.fromRGB(200,50,50)
	label.TextColor3 = Color3.fromRGB(255,255,255)
	label.TextStrokeTransparency = 0
	label.TextSize = 12
	label.TextWrapped = true
	label.TextYAlignment = Enum.TextYAlignment.Top
	label.Visible = false
	label.Font = Enum.Font.SourceSansBold
	label.Parent = container

	return label
end

-- Tracker Tab
local trackerFrame = tabs["Tracker"]
local toggleESP = createButton(trackerFrame,"Show: ON",10)
local followBtn = createButton(trackerFrame,"Follow Player",50)
local stopFollowBtn = createButton(trackerFrame,"Stop Follow",120)
local nameBox = createTextBox(trackerFrame,"Player Name",85)
local warningLabel = createWarningLabel(trackerFrame)

local function createNameESP(char,player)
	if char:FindFirstChild("Head") and not char.Head:FindFirstChild("NameESP") then
		local billboard = Instance.new("BillboardGui")
		billboard.Name = "NameESP"
		billboard.Adornee = char.Head
		billboard.Size = UDim2.new(0,150,0,30)
		billboard.StudsOffset = Vector3.new(0,2,0)
		billboard.AlwaysOnTop = true
		billboard.Enabled = espEnabled
		billboard.Parent = char.Head

		local label = Instance.new("TextLabel")
		label.Size = UDim2.new(1,0,1,0)
		label.BackgroundTransparency = 1
		label.Text = player.Name
		label.TextColor3 = Color3.fromRGB(255,0,0)
		label.TextStrokeTransparency = 0
		label.TextSize = 14
		label.Parent = billboard
	end
end

toggleESP.MouseButton1Click:Connect(function()
	espEnabled = not espEnabled
	toggleESP.Text = "Show: "..(espEnabled and "ON" or "OFF")
	for _,p in pairs(Players:GetPlayers()) do
		if p.Character and p.Character:FindFirstChild("Head") then
			local esp = p.Character.Head:FindFirstChild("NameESP")
			if esp then
				esp.Enabled = espEnabled or (followPlayer == p)
			end
		end
	end
end)

followBtn.MouseButton1Click:Connect(function()
	nameBox.Visible = not nameBox.Visible
end)

nameBox.FocusLost:Connect(function(enter)
	if enter then
		local txt = nameBox.Text:lower()
		local matches = {}
		for _,p in pairs(Players:GetPlayers()) do
			if p.Name:lower():sub(1,#txt) == txt or p.DisplayName:lower():sub(1,#txt) == txt then
				table.insert(matches,p)
			end
		end

		if #matches == 1 then
			followPlayer = matches[1]
			print("Following: "..followPlayer.Name)
			nameBox.Visible = false
			nameBox.Text = ""
		elseif #matches > 1 then
			warningLabel.Text = "Multiple players found:\n"
			for _,pp in pairs(matches) do
				warningLabel.Text = warningLabel.Text..pp.Name.."\n"
			end
			warningLabel.Visible = true
			task.delay(2,function() warningLabel.Visible = false end)
		else
			warningLabel.Text = "No player found."
			warningLabel.Visible = true
			task.delay(2,function() warningLabel.Visible = false end)
		end
	end
end)

stopFollowBtn.MouseButton1Click:Connect(function()
	if followPlayer then
		local esp = followPlayer.Character and followPlayer.Character:FindFirstChild("Head") and followPlayer.Character.Head:FindFirstChild("NameESP")
		if esp then
			esp.Enabled = espEnabled
		end
		print("Stopped following "..followPlayer.Name)
		followPlayer = nil
	end
end)

local function onCharacterAdded(char,player)
	char:WaitForChild("Head")
	createNameESP(char,player)
end

for _,p in pairs(Players:GetPlayers()) do
	if p ~= localPlayer then
		p.CharacterAdded:Connect(function(c) onCharacterAdded(c,p) end)
		if p.Character then onCharacterAdded(p.Character,p) end
	end
end

Players.PlayerAdded:Connect(function(p)
	if p ~= localPlayer then
		p.CharacterAdded:Connect(function(c) onCharacterAdded(c,p) end)
	end
end)

RunService.RenderStepped:Connect(function()
	if followPlayer and followPlayer.Character and followPlayer.Character:FindFirstChild("Head") then
		local esp = followPlayer.Character.Head:FindFirstChild("NameESP")
		if esp then esp.Enabled = true end
	end
end)

